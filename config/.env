OLLAMA_API_URL=127.0.0.1
OLLAMA_PORT=11434
VOICE=pf_dora
SERVER_ADDRESS=192.168.0.6
SERVER_PORT=8000
# large-v3, large-v2, turbo...
WHISPER_MODEL=turbo
#fp16 or int8
WHISPER_PRECISION=int8

# Level 0 totally local.
# Level 1 tasks audio transcription to the secondary server.
# Level 2 adds audio synth to level 1
# Level 3 offloads the audio processing entirely
# level 4 offloads llm model workload
# level 5 all workloads are offloaded
OFFLOAD_LEVEL=0